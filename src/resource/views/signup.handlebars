<html>
	<head>
		<meta charset="UTF-8">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

		<title>Đăng ký - ĐXT Đảo Rồng Mobile</title>
		<link rel = "icon" href = "https://userpic.codeforces.org/1657001/title/7b916a641c436c8c.jpg">
		<link rel = "stylesheet" href = "/css/signup.css">
	</head>
	<body style = "background-color: rgb(228, 136, 146)">
		<div class = "titlePane">
            <div class="smallPane">
                <img src = "https://userpic.codeforces.org/1657001/title/7b916a641c436c8c.jpg" style = "width: 70;height: 70;border-radius: 50%;"> 
                <label style="margin-left: 30px;" onclick = "window.location.href='/';"> <b> Trang chủ</b></label>
            </div>
            <div class = "smallPane">
                <label onclick = "window.location.href='login';"> <b>Đăng nhập /</b> </label>
                <label><b> Đăng ký</b>  </label>
            </div>
        </div>

		<div class="pane">
			<h1>Đăng ký</h1>
			<hr>
			<form class="secondPane" id="signupForm" method="post" action="/signup" onsubmit="return false;">
				<div>
					<label> Tên đăng nhập (account) </label>
					<input type="text" name="account" id="account" placeholder="Tên đăng nhập" required>
				</div>
				<div>
					<label> Mật khẩu </label>
					<input type="password" name="password" id="password" placeholder="Mật khẩu" required>
				</div>
				<div>
					<label> Xác nhận mật khẩu </label>
					<input type="password" name="confirm_password" id="confirm_password" placeholder="Xác nhận mật khẩu" required>
				</div>
				<div>
					<label> Họ tên </label>
					<input type="text" name="full_name" id="full_name" placeholder="Họ và tên" required>
				</div>
				<div>
					<label> Ngày sinh </label>
					<input type="date" name="birthday" id="birthday">
				</div>
				<div>
					<label> Số điện thoại </label>
					<input type="tel" name="phone_number" id="phone_number" placeholder="0123456789" pattern="[0-9]{9,15}">
				</div>
				<div style="display:flex;align-items:center;gap:8px;">
					<input type="checkbox" id="agree" name="agree" style="transform: scale(1.2);">
					<label for="agree"> Tôi đồng ý với điều khoản sử dụng</label>
				</div>
				<input type="submit" value="Đăng ký" id="signupButton">
			</form>
			<pre id="noti"></pre>
		</div>

		<script>
		document.getElementById('signupForm').addEventListener('submit', function(e){
			e.preventDefault();
			const account = document.getElementById('account').value.trim();
			const password = document.getElementById('password').value;
			const confirm = document.getElementById('confirm_password').value;
			const fullName = document.getElementById('full_name').value.trim();
			const birthday = document.getElementById('birthday').value;
			const phone = document.getElementById('phone_number').value.trim();
			const agree = document.getElementById('agree').checked;

			const noti = document.getElementById('noti');
			const btn = document.getElementById('signupButton');
			noti.textContent = '';
			if(password !== confirm){
				noti.textContent = 'Mật khẩu và xác nhận mật khẩu không khớp.';
				return;
			}
			if(!agree){
				noti.textContent = 'Bạn phải đồng ý với điều khoản để tiếp tục.';
				return;
			}

			btn.disabled = true;
			btn.textContent = 'Đang gửi...';

			fetch('/signup', {
				method: 'POST',
				headers: {'Content-Type':'application/json'},
				body: JSON.stringify({account, password, full_name: fullName, birthday, phone_number: phone})
			}).then(async (r) => {
				// if server returned an error page (html), try to surface text
				if (!r.ok) {
					let txt;
					try { txt = await r.text(); } catch(e) { txt = 'Lỗi server: ' + r.status; }
					throw new Error(txt || ('HTTP ' + r.status));
				}
				// parse JSON safely
				return r.json();
			}).then(data=>{
				if ( data && data.ok ) {
					window.location.href = '/signup_success';
					return;
				}
				btn.disabled = false;
				btn.textContent = 'Đăng ký';
				noti.textContent = data && data.message ? data.message : 'Không thể tạo tài khoản';
			}).catch(err=>{
				btn.disabled = false;
				btn.textContent = 'Đăng ký';
				console.error('signup fetch error', err);
				noti.textContent = err.message || 'Lỗi khi gửi yêu cầu.';
			});
		});
		</script>
	</body>
</html>